void readUltrasonic()
{
  // Send ultrasonic pulse
  digitalWrite(TRIG_PIN, LOW);
  delayMicroseconds(2);

  digitalWrite(TRIG_PIN, HIGH);
  delayMicroseconds(10);

  digitalWrite(TRIG_PIN, LOW);

  // Receive echo
  long duration = pulseIn(
    ECHO_PIN,
    HIGH,
    30000
  );

  bool validReading = duration > 0;

  if (validReading)
  {
    distanceValue = duration * 0.034 / 2;
  }
  else
  {
    // No object or no echo received
    distanceValue = 400;
  }

  Serial.print("Object Distance: ");
  Serial.print(distanceValue);
  Serial.println(" cm");

 // Send distance to Blynk V1
  Blynk.virtualWrite(V1, distanceValue);

  bool objectDetected =
    validReading &&
    distanceValue > 0 &&
    distanceValue <= FOOD_DETECTION_DIST;

  /*
    Servo only opens when condition changes from:

    No object -> Object detected

    This prevents repeated dispensing while the
    same object remains in front of the sensor.
  */

  if (
    objectDetected &&
    !objectPreviouslyDetected
  )
  {
    Serial.println(
      "Object detected within 5 cm!"
    );

    openFeeder();
  }

  objectPreviouslyDetected = objectDetected;
} 
